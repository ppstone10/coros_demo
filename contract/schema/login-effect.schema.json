{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/login-effect.schema.json",
  "title": "LoginEffect",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "type",
        "user"
      ],
      "properties": {
        "type": {
          "const": "NavigateHome"
        },
        "user": {
          "$ref": "./user-dto.schema.json"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "type",
        "message"
      ],
      "properties": {
        "type": {
          "const": "ShowMessage"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  ]
}
